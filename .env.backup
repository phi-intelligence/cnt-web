# LiveKit Configuration (update with your LiveKit server)
LIVEKIT_WS_URL=wss://livekit.yourdomain.com
LIVEKIT_HTTP_URL=https://livekit.yourdomain.com
LIVEKIT_API_KEY=your_livekit_api_key
